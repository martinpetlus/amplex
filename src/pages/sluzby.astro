---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations } from "../i18n/ui";
import { servicesContent } from "../i18n/services";

const t = useTranslations("sk");
const services = servicesContent.sk;
const contactHref = getRelativeLocaleUrl("sk", "kontakt");
---

<BaseLayout
  title={`${services.title} | ${t("site.title")}`}
  wide
  page="services"
>
  <h1 class="text-4xl font-bold tracking-tight">{services.title}</h1>
  <p class="mt-4 max-w-3xl text-lg text-slate-600">{services.intro}</p>

  <div class="mt-10">
    <ServicesGrid lang="sk" detailed />
  </div>

  <div class="mt-6">
    <a
      href={contactHref}
      class="inline-flex items-center gap-1 font-medium text-sky-600 hover:text-sky-800"
    >
      {t("nav.contact")}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</BaseLayout>
