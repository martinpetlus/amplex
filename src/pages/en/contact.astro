---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../i18n/ui";

const t = useTranslations("en");
const mailtoHref = `mailto:${t("contact.email")}?subject=${encodeURIComponent(
  t("contact.mailSubject"),
)}&body=${encodeURIComponent(t("contact.mailBody"))}`;
---

<BaseLayout
  title={`${t("contact.title")} | ${t("site.title")}`}
  description={t("contact.intro")}
  page="contact"
>
  <h1 class="text-4xl font-bold tracking-tight">{t("contact.title")}</h1>
  <p class="mt-4 text-lg text-slate-600">{t("contact.intro")}</p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    <div
      class="flex items-center gap-4 rounded-xl border border-slate-200 bg-white p-5 shadow-sm"
    >
      <span
        class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sky-600"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"
          ></path>
        </svg>
      </span>
      <div class="min-w-0 flex-1">
        <span class="block text-sm font-medium text-slate-500"
          >{t("contact.phoneLabel")}</span
        >
        <a
          href={`tel:${t("contact.phone").replace(/\s+/g, "")}`}
          class="block truncate font-semibold text-slate-900 hover:text-sky-700"
          >{t("contact.phone")}</a
        >
      </div>
      <button
        type="button"
        class="copy-btn flex h-9 w-9 shrink-0 items-center justify-center rounded-lg text-slate-400 transition hover:bg-slate-100 hover:text-slate-600"
        data-copy={t("contact.phone").replace(/\s+/g, "")}
        data-label-copy={t("contact.copy")}
        data-label-copied={t("contact.copied")}
        aria-label={t("contact.copy")}
        title={t("contact.copy")}
      >
        <svg
          class="copy-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
          ></path>
        </svg>
        <svg
          class="check-icon hidden text-green-600"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </button>
    </div>

    <div
      class="flex items-center gap-4 rounded-xl border border-slate-200 bg-white p-5 shadow-sm"
    >
      <span
        class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sky-600"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
      </span>
      <div class="min-w-0 flex-1">
        <span class="block text-sm font-medium text-slate-500"
          >{t("contact.emailLabel")}</span
        >
        <a
          href={mailtoHref}
          class="block truncate font-semibold text-slate-900 hover:text-sky-700"
          >{t("contact.email")}</a
        >
      </div>
      <button
        type="button"
        class="copy-btn flex h-9 w-9 shrink-0 items-center justify-center rounded-lg text-slate-400 transition hover:bg-slate-100 hover:text-slate-600"
        data-copy={t("contact.email")}
        data-label-copy={t("contact.copy")}
        data-label-copied={t("contact.copied")}
        aria-label={t("contact.copy")}
        title={t("contact.copy")}
      >
        <svg
          class="copy-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
          ></path>
        </svg>
        <svg
          class="check-icon hidden text-green-600"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </button>
    </div>
  </div>

  <section
    class="mt-8 rounded-xl border border-slate-200 bg-white p-5 shadow-sm"
  >
    <dl class="grid gap-3 sm:grid-cols-3">
      <div>
        <dt class="text-sm text-slate-500">{t("contact.companyNameLabel")}</dt>
        <dd class="font-semibold text-slate-900">{t("contact.companyName")}</dd>
      </div>
      <div>
        <dt class="text-sm text-slate-500">{t("contact.icoLabel")}</dt>
        <dd class="font-semibold text-slate-900">{t("contact.ico")}</dd>
      </div>
      <div>
        <dt class="text-sm text-slate-500">{t("contact.dicLabel")}</dt>
        <dd class="font-semibold text-slate-900">{t("contact.dic")}</dd>
      </div>
    </dl>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const value = btn.dataset.copy;
      if (!value) return;
      try {
        await navigator.clipboard.writeText(value);
      } catch {
        return;
      }
      const copyIcon = btn.querySelector(".copy-icon");
      const checkIcon = btn.querySelector(".check-icon");
      const copied = btn.dataset.labelCopied ?? "";
      const copy = btn.dataset.labelCopy ?? "";
      copyIcon?.classList.add("hidden");
      checkIcon?.classList.remove("hidden");
      btn.setAttribute("aria-label", copied);
      btn.setAttribute("title", copied);
      window.setTimeout(() => {
        copyIcon?.classList.remove("hidden");
        checkIcon?.classList.add("hidden");
        btn.setAttribute("aria-label", copy);
        btn.setAttribute("title", copy);
      }, 1500);
    });
  });
</script>
