---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../i18n/ui";

const t = useTranslations("en");
---

<BaseLayout title={`${t("contact.title")} | ${t("site.title")}`}>
  <h1 class="text-4xl font-bold tracking-tight">{t("contact.title")}</h1>
  <p class="mt-4 text-lg text-slate-600">{t("contact.intro")}</p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    <a
      href={`tel:${t("contact.phone").replace(/\s+/g, "")}`}
      class="group flex items-center gap-4 rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-sky-300 hover:shadow-md"
    >
      <span
        class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sky-600 transition group-hover:bg-sky-100"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"
          ></path>
        </svg>
      </span>
      <span class="min-w-0">
        <span class="block text-sm font-medium text-slate-500"
          >{t("contact.phoneLabel")}</span
        >
        <span class="block truncate font-semibold text-slate-900"
          >{t("contact.phone")}</span
        >
      </span>
    </a>

    <a
      href={`mailto:${t("contact.email")}`}
      class="group flex items-center gap-4 rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-sky-300 hover:shadow-md"
    >
      <span
        class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sky-600 transition group-hover:bg-sky-100"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
      </span>
      <span class="min-w-0">
        <span class="block text-sm font-medium text-slate-500"
          >{t("contact.emailLabel")}</span
        >
        <span class="block truncate font-semibold text-slate-900"
          >{t("contact.email")}</span
        >
      </span>
    </a>
  </div>
</BaseLayout>
