---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServicesGrid from "../../components/ServicesGrid.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslations } from "../../i18n/ui";
import { servicesContent } from "../../i18n/services";

const t = useTranslations("en");
const services = servicesContent.en;
const servicesHref = getRelativeLocaleUrl("en", "services");
---

<BaseLayout>
  <h1 class="text-4xl font-bold tracking-tight">{t("hero.title")}</h1>
  <p class="mt-4 text-lg text-slate-600">{t("hero.subtitle")}</p>

  <section class="mt-16">
    <h2 class="text-2xl font-bold tracking-tight">{services.title}</h2>
    <p class="mt-2 text-slate-600">{services.intro}</p>
    <div class="mt-6">
      <ServicesGrid lang="en" />
    </div>
    <a
      href={servicesHref}
      class="mt-6 inline-flex items-center gap-1 font-medium text-sky-600 hover:text-sky-800"
    >
      {t("services.home.cta")}
      <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>
