---
import { servicesContent, type PillarId } from "../i18n/services";
import type { Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
  detailed?: boolean;
}

const { lang, detailed = false } = Astro.props;
const { pillars } = servicesContent[lang];

const icons: Record<PillarId, string> = {
  automation: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  data: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  ai: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 4.8L18.6 9l-4.7 1.2L12 15l-1.9-4.8L5.4 9l4.7-1.2L12 3z"/><path d="M19 15l.8 2.2L22 18l-2.2.8L19 21l-.8-2.2L16 18l2.2-.8L19 15z"/></svg>`,
};
---

<div class="grid gap-4 sm:grid-cols-3">
  {
    pillars.map((pillar) => (
      <div class="flex flex-col rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-sky-300 hover:shadow-md">
        <span
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-sky-50 text-sky-600"
          set:html={icons[pillar.id]}
        />
        <h3 class="mt-4 text-lg font-semibold text-slate-900">
          {pillar.title}
        </h3>
        <p class="mt-2 text-sm text-slate-600">{pillar.summary}</p>
        {detailed && (
          <ul class="mt-4 space-y-2 text-sm text-slate-600">
            {pillar.items.map((item) => (
              <li class="flex items-start gap-2">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="mt-0.5 shrink-0 text-sky-600"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        )}
      </div>
    ))
  }
</div>
