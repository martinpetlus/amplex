---
import "../styles/global.css";
import { getRelativeLocaleUrl } from "astro:i18n";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import { defaultLang, type Lang, useTranslations } from "../i18n/ui";
import { routes, type RouteKey } from "../i18n/routes";

interface Props {
  title?: string;
  wide?: boolean;
  page?: RouteKey;
}

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const { title = t("site.title"), wide = false, page = "home" } = Astro.props;
const base = import.meta.env.BASE_URL;
const homeHref = getRelativeLocaleUrl(lang, routes.home[lang]);
const servicesHref = getRelativeLocaleUrl(lang, routes.services[lang]);
const aboutHref = getRelativeLocaleUrl(lang, routes.about[lang]);
const contactHref = getRelativeLocaleUrl(lang, routes.contact[lang]);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${base.replace(/\/$/, "")}/favicon.svg`}
    />
    <link
      rel="icon"
      type="image/png"
      href={`${base.replace(/\/$/, "")}/favicon.png`}
    />
    <link
      rel="apple-touch-icon"
      href={`${base.replace(/\/$/, "")}/favicon.png`}
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <header
      class="flex items-center justify-between border-b border-slate-200 px-6 py-4"
    >
      <div class="flex items-center gap-6">
        <a href={homeHref} class="flex items-center gap-2 font-semibold">
          <img
            src={`${base.replace(/\/$/, "")}/logo.svg`}
            alt=""
            width="32"
            height="32"
            class="h-8 w-8"
          />
          <span class="text-lg">{t("site.title")}</span>
        </a>
        <nav class="hidden items-center gap-4 text-sm sm:flex">
          <a href={homeHref} class="hover:underline">{t("nav.home")}</a>
          <a href={servicesHref} class="hover:underline">{t("nav.services")}</a>
          <a href={aboutHref} class="hover:underline">{t("nav.about")}</a>
          <a href={contactHref} class="hover:underline">{t("nav.contact")}</a>
        </nav>
      </div>
      <div class="flex items-center gap-2">
        <LanguageSwitcher page={page} />
        <details class="group relative sm:hidden">
          <summary
            class="flex cursor-pointer list-none items-center rounded p-1 text-slate-700 hover:bg-slate-200"
            aria-label={t("nav.menu")}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="3" y1="6" x2="21" y2="6" class="group-open:hidden"
              ></line>
              <line x1="3" y1="12" x2="21" y2="12" class="group-open:hidden"
              ></line>
              <line x1="3" y1="18" x2="21" y2="18" class="group-open:hidden"
              ></line>
              <line
                x1="6"
                y1="6"
                x2="18"
                y2="18"
                class="hidden group-open:block"></line>
              <line
                x1="6"
                y1="18"
                x2="18"
                y2="6"
                class="hidden group-open:block"></line>
            </svg>
          </summary>
          <nav
            aria-label="Main"
            class="absolute right-0 z-10 mt-1 min-w-[8rem] rounded-md border border-slate-200 bg-white py-1 text-sm shadow-md"
          >
            <a
              href={homeHref}
              class="block px-3 py-1.5 text-slate-700 hover:bg-slate-100"
              >{t("nav.home")}</a
            >
            <a
              href={servicesHref}
              class="block px-3 py-1.5 text-slate-700 hover:bg-slate-100"
              >{t("nav.services")}</a
            >
            <a
              href={aboutHref}
              class="block px-3 py-1.5 text-slate-700 hover:bg-slate-100"
              >{t("nav.about")}</a
            >
            <a
              href={contactHref}
              class="block px-3 py-1.5 text-slate-700 hover:bg-slate-100"
              >{t("nav.contact")}</a
            >
          </nav>
        </details>
      </div>
    </header>
    <main class={`mx-auto px-6 py-12 ${wide ? "max-w-5xl" : "max-w-3xl"}`}>
      <slot />
    </main>
  </body>
</html>
